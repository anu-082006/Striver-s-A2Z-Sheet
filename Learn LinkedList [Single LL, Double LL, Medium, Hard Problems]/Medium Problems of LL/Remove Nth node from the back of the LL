class Solution {
    public ListNode removeNthFromEnd(ListNode head, int n) {
        ListNode temp = head;
        int size = 0;
        while(temp != null) {
            size ++;
            temp = temp.next;
        }
        if(n==size) {
            return head.next;
        }
        temp = head;
        ListNode prev = null;
        int index = size-n+1;
        for(int i=1; i<index; i++) {
            prev = temp;
            temp = temp.next;
        }
        prev.next = temp.next;
        return head;
    }
}
