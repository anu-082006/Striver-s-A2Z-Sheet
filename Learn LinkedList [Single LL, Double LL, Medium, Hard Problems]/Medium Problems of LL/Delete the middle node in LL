class Solution {
    public ListNode deleteMiddle(ListNode head) {
        int size = 0;
        ListNode temp = head;
        while(temp != null) {
            size ++;
            temp = temp.next;
        }
        if(size == 0) {
            return null;
        }
        if(size == 1) {
            return head.next;
        }
        temp = head;
        ListNode prev = null;
        for(int i=0; i<size/2; i++) {
            prev = temp;
            temp = temp.next;
        }
        prev.next = temp.next;
        return head;
    }
}
